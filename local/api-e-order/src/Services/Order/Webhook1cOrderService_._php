<?php

declare(strict_types=1);

namespace OrderApi\Services\Order;

use OrderApi\DB\Repositories\DealerUserRepository;
use OrderApi\DB\Repositories\OrderRepository;
use OrderApi\DB\Repositories\OrderStatusRepository;
use OrderApi\Services\LogService;

final readonly class Webhook1cOrderService_
{
  /**
   * Обновляет статус заказа и дополнительные поля по номеру заказа.
   *
   * @param string $orderNumber Номер заказа из 1С.
   * @param string $statusCode Код нового статуса.
   * @param string $statusDate Дата установки статуса.
   * @param array $extraData Массив дополнительных полей для обновления (ключ => значение).
   *
   * @return array|null Обновленный массив заказа или null.
   * @throws \RuntimeException Если заказ или статус не найдены, или нет данных для обновления.
   * @throws \Exception Произошла ошибка обновления в БД
   */
  public function updateStatusByNumber(
    string $orderNumber,
    string $statusCode,
    string $statusDate,
    array $extraData = []
  ): ?array {

    $order = OrderRepository::getByNumber($orderNumber);
    if (!$order) {
      throw new \RuntimeException("Заказ с номером {$orderNumber} не найден в системе!");
    }

    $status = OrderStatusRepository::findByCode($statusCode);
    if (!$status) {
      throw new \RuntimeException("Статус с кодом {$statusCode} не найден в системе!");
    }

    $fieldsToUpdate = [];

    // Проверяем, изменился ли статус
    if ((int)$order['status_id'] !== (int)$status['id']) {
      $fieldsToUpdate['status_id'] = $status['id'];
      $fieldsToUpdate['status_history'] = array_merge(
        [ //новый статус добавляется в начало
          [
            'id'   => $status['id'],
            'code' => $statusCode,
            'date' => $statusDate,
          ]
        ],
        $order['status_history'] ?? []
      );
    }

    // Добавляем дополнительные данные (если есть)
    if (!empty($extraData)) {
      $fieldsToUpdate = array_merge($fieldsToUpdate, $extraData);
    }

    // Финальная проверка: есть ли что обновлять?
    if (empty($fieldsToUpdate)) {
      throw new \RuntimeException(
        "Для заказа №{$orderNumber} статус '{$statusCode}' уже установлен, и нет дополнительных данных для обновления."
      );
    }

    // Сохранение в БД
    return OrderRepository::update((int)$order['id'], $fieldsToUpdate);
  }

  /**
   * Создает заказ на основе данных из 1С.
   *
   * @param array $data Входящий JSON массив
   * @return array Созданный заказ
   * @throws \RuntimeException Если заказ уже существует (код 409) или данные некорректны
   * @throws \Exception Ошибки БД
   */
  public function createOrderFrom1C(array $data): array
  {
    $ligronNumber = (string)($data['ligron_number'] ?? '');

    // 1. Валидация номера
    if (empty($ligronNumber)) {
      throw new \RuntimeException('Не передан обязательный параметр ligron_number', 400);
    }

    // 2. Проверка на дубликат
    $existingOrder = OrderRepository::getByNumber($ligronNumber);

    if ($existingOrder) {
      throw new \RuntimeException("Заказ с номером {$ligronNumber} уже существует.", 409);
    }

    // 3. Маппинг данных (Внешние ID -> Внутренние ID)
    $fields = $this->map1CDataToInternal($data);

    // Явно устанавливаем номер и источник
    $fields['number'] = $ligronNumber;

    // 4. Логируем и сохраняем
    LogService::info("1C Create: Заказ {$ligronNumber}", $fields, 'webhook_1c');

    return OrderRepository::create($fields);
  }

  /**
   * Преобразование внешних данных (ИНН, Код салона) во внутренние ID (dealer_id, user_id)
   */
  private function map1CDataToInternal(array $data): array
  {
    $inn = (string)($data['client'] ?? '');
    $salonCode = (string)($data['salon'] ?? '');

    // Определяем Дилера по ИНН ---
    $dealerInfo = DealerUserRepository::getDealerByInn($inn);

    $dealerPrefix = null;
    $dealerUserId = null;

    if ($dealerInfo) {
      $dealerPrefix = $dealerInfo['prefix'];
      $dealerId = (int)$dealerInfo['id'];

      // Определяем Пользователя (Салон) по Коду
      if (!empty($salonCode)) {
        $dealerUserId = DealerUserRepository::findUserIdBySalonCode($dealerId, $dealerPrefix, $salonCode);
      }
    } else {
      LogService::error("1C Webhook: Не найден дилер по ИНН {$inn}", $data, 'webhook_1c');
      throw new \RuntimeException("1C Webhook: Не найден дилер по ИНН {$inn}");
    }

    // Определяем Статус
    //ToDo если статус не найден или возвратилась ошибка, то прекратить создание и выбросить ошибку
    $statusId = null;
    if (!empty($data['status_code'])) {
      $status = OrderStatusRepository::findByCode((string)$data['status_code']);
      $statusId = $status['id'] ?? null;
    }

    // --- Г. Парсим Дату готовности ---
    $readyDate = null;
    if (!empty($data['production_date'])) {
      try {
        // 1С шлет дату строкой, например "14.12.2025"
        $readyDate = new Date($data['production_date'], 'd.m.Y');
      } catch (\Throwable) {}
    }

    //ToDo если origin_type не равен OrderTable::ORIGIN_TYPE_1C или  OrderTable::ORIGIN_TYPE_CALC выбросить ошибку

    return [
      'name'            => $data['name'] ?? 'Заказ из 1С',
      'comment'         => $data['comment'] ?? '',

      // Привязки
      'dealer_prefix'   => $dealerPrefix,
      'dealer_user_id'  => $dealerUserId,
      'manager_id'      => isset($data['manager_id']) ? (int)$data['manager_id'] : null,

      'status_id'       => $statusId,

      // Числовые поля
      'production_time' => (int)($data['production_time'] ?? 0),
      'percent_payment' => (int)($data['percent_payment'] ?? 0),
      'ready_date'      => $readyDate,

      // Мест создания
      'origin_type' => $data['origin_type'],

      // Технические поля
      'created_by'      => 0, // 0 = Система (не человек)
      'created_by_id'   => 0,
    ];
  }

}